            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "Build (Linux aes_encrypt)",
            "command": "bash",
            "args": [
                "-lc",
                "/usr/bin/g++-13 -fdiagnostics-color=always -g -std=c++17 -maes -msse2 -msse4.1 ./aes_encrypt.cpp -I. -o ./aes_encrypt_linux"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
